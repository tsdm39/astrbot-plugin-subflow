# ============================================================
# 复制本文件为 .key 后填入实际值。.key 已被 gitignore，不要提交。
# ============================================================

# ──── 腾讯文档 API（D2：手动续期模式，无 client_secret 也能跑）────
# 单 key 写法：填下面三元组即可（最常见）
TENCENT_DOC_CLIENT_ID=
TENCENT_DOC_OPEN_ID=
# 30 天 JWT；过期前到开放平台后台重新生成并替换
TENCENT_DOC_ACCESS_TOKEN=
# 默认文档 fileID（300000000$xxx 形式）；按名绑定时在此文档下找子表
# 未填则 /绑定 命令不可用，必须用 /绑定id
TENCENT_DOC_DEFAULT_FILE_ID=

# ──── 多 key 轮换池（D18：提升日调用额度）────
# 多套已各自授权同一批文档的凭据，JSON 数组；非空时取代上面的三元组。
# 每套 = {client_id, open_id, access_token}。N 套 ≈ 把 2000/天叠到 N×2000。
# 前提：每套背后是不同的开发者账号，且都授权了同一批智能表。
# 示例：SUBFLOW_TENCENT_DOC_KEYS=[{"client_id":"c1","open_id":"o1","access_token":"t1"},{"client_id":"c2","open_id":"o2","access_token":"t2"}]
SUBFLOW_TENCENT_DOC_KEYS=[]
# 视为"限流/配额耗尽"的 ret 码集合（命中则该 key 短时冷却并换把）；
# 腾讯未公布确切码，观测到后填进来，如 [120001]
SUBFLOW_TENCENT_DOC_RATE_LIMIT_RETS=[]
# 某把 key 触发限流后的冷却秒数
SUBFLOW_TENCENT_DOC_KEY_COOLDOWN=60

# ──── 群配置 ────
# 总群 QQ 群号（D9：仅查询、推送不进总群）；留空则不启用总群
# 注意：空值合法，Bot 会自动处理（D14）
SUBFLOW_MAIN_GROUP_ID=
# 超级管理员 QQ 列表（JSON 数组），可执行跨群命令（如 /绑定列表 全部）
SUBFLOW_ADMIN_QQ_LIST=[]

# ──── 业务参数 ────
# 单人最大持有未完成任务数（0 = 不限）
SUBFLOW_MAX_TASKS_PER_USER=5
# 缓存全量同步间隔（分钟）
SUBFLOW_SYNC_INTERVAL=30
# /删除任务 二次确认窗口（秒）
SUBFLOW_CONFIRM_TIMEOUT=30
# access_token 距过期多少天开始日志告警
SUBFLOW_TOKEN_WARN_DAYS=7
# 运行时数据目录（bindings.json / pipelines.json / episode_pipelines.json）
SUBFLOW_DATA_DIR=./data
# 默认流水线 DSL（番剧未设置自定义流水线时用这个）
SUBFLOW_DEFAULT_PIPELINE=翻译[分段] → 时轴[分段] → 校对 → 后期 → 监制 → 压制
